{
  "$schema": "../apps/web/node_modules/wrangler/config-schema.json",
  "name": "quieter-review-webworkerscript",
  "main": "../.review-deploy/server.js",
  "compatibility_date": "2026-07-11",
  "compatibility_flags": ["nodejs_compat"],
  "no_bundle": true,
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "review.quieter.email",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "../.review-deploy/client",
    "binding": "ASSETS",
  },
  "hyperdrive": [
    {
      "binding": "AppDatabaseV2",
      "id": "3781be7e3f0d40cd83464e38310eed54",
    },
  ],
  "vars": {
    "AI_USD_TO_EUR_RATE": "1",
    "AWS_DEFAULT_REGION": "eu-central-1",
    "AWS_REGION": "eu-central-1",
    "BETTER_AUTH_APP_NAME": "Quieter Review",
    "BETTER_AUTH_TRUSTED_ORIGINS": "",
    "BETTER_AUTH_URL": "https://review.quieter.email",
    "GOOGLE_AUTH_CLIENT_ID": "154964706403-vbnsffd5jus78g9um26f20dkmi2q0hsu.apps.googleusercontent.com",
    "GOOGLE_CALENDAR_CLIENT_ID": "154964706403-ghlcd523kb9qbmvrdc91o9ddfghierp3.apps.googleusercontent.com",
    "GOOGLE_GMAIL_CLIENT_ID": "154964706403-is4ko1cbs6juk2l8givi5fa74qff8b4c.apps.googleusercontent.com",
    "NODE_ENV": "production",
    "QUIETER_AUTH_MAIL_MODE": "console",
    "QUIETER_AUTH_MAIL_SENDER": "auth@quieter.email",
    "QUIETER_DEPLOYMENT_ENV": "preview",
    "QUIETER_GMAIL_AI_AUTOMATION_ENABLED": "false",
    "QUIETER_MAIL_API_URL": "https://review.quieter.email/api/v1/send",
    "QUIETER_PREVIEW_PERSONAS_ENABLED": "false",
    "SENTRY_ENVIRONMENT": "review",
    "SST_RESOURCE_App": "{\"name\":\"quieter\",\"stage\":\"review\"}",
    "VITE_LOGO_DEV_PUBLISHABLE_KEY": "",
    "VITE_PUBLIC_POSTHOG_HOST": "https://eu.i.posthog.com",
    "VITE_PUBLIC_POSTHOG_PROJECT_TOKEN": "",
    "VITE_QUIETER_PREVIEW_PERSONAS_ENABLED": "false",
    "VITE_SENTRY_DSN": "",
  },
  "observability": {
    "enabled": false,
  },
}
