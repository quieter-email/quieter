  "devDependencies": {
    "@quieter/config": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-router": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
