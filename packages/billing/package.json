{
  "name": "@quieter/billing",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./credits": "./src/credits.ts",
    "./entitlements": "./src/entitlements.ts",
    "./polar": "./src/polar.ts",
    "./plans": "./src/plans.ts",
    "./ses-pricing": "./src/ses-pricing.ts",
    "./organization-mail-usage": "./src/organization-mail-usage.ts"
  },
  "scripts": {
    "catalog:sync": "bun --env-file=../../.env.local scripts/sync-polar-catalog.ts",
    "credit-usage:sync": "bun --env-file=../../.env.local scripts/sync-polar-credit-usage.ts",
    "fmt": "oxfmt --config ../../oxfmt.json .",
    "fmt:check": "oxfmt --check --config ../../oxfmt.json .",
    "lint": "bun --cwd ../.. oxlint --config oxlint.json packages/billing",
    "lint:fix": "bun --cwd ../.. oxlint --fix --config oxlint.json packages/billing",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@orpc/server": "catalog:",
    "@polar-sh/sdk": "^0.48.1",
    "@quieter/database": "workspace:*",
    "@quieter/env": "workspace:*",
    "drizzle-orm": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@quieter/config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
