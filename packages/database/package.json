{
  "name": "@quieter/database",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "db:check": "drizzle-kit check && bun scripts/check-schema-drift.ts",
    "db:deploy": "bun scripts/deploy-migrations.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/run-migrations.ts",
    "db:push": "bun --env-file=../../.env.local drizzle-kit push",
    "fmt": "oxfmt --config ../../oxfmt.json .",
    "fmt:check": "oxfmt --check --config ../../oxfmt.json .",
    "lint": "bun --cwd ../.. oxlint --config oxlint.json packages/database",
    "lint:fix": "bun --cwd ../.. oxlint --fix --config oxlint.json packages/database",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "catalog:",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@quieter/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "drizzle-kit": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
