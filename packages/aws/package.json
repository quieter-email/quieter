{
  "name": "@quieter/aws",
  "private": true,
  "type": "module",
  "exports": {
    "./inbound": "./src/inbound.ts",
    "./outbound": "./src/outbound.ts",
    "./receipt": "./src/receipt.ts"
  },
  "scripts": {
    "dev": "bun ../../scripts/sst.ts dev",
    "fmt": "oxfmt --config ../../oxfmt.json .",
    "fmt:check": "oxfmt --check --config ../../oxfmt.json .",
    "lint": "bun --cwd ../.. oxlint --config oxlint.json packages/aws",
    "lint:fix": "bun --cwd ../.. oxlint --fix --config oxlint.json packages/aws",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/client-sesv2": "catalog:",
    "@quieter/billing": "workspace:*",
    "@quieter/orpc": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@quieter/config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
