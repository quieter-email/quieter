{
  "name": "@quieter/aws",
  "private": true,
  "type": "module",
  "exports": {
    "./inbound": "./src/inbound.ts",
    "./outbound": "./src/outbound.ts",
    "./receipt": "./src/receipt.ts"
  },
  "scripts": {
    "dev": "bunx --env-file=../../.env.local sst dev --config ../../sst.config.ts --stage mail-dev",
    "fmt": "oxfmt --config ../../oxfmt.json .",
    "fmt:check": "oxfmt --check --config ../../oxfmt.json .",
    "lint": "oxlint --config ../../oxlint.json .",
    "lint:fix": "oxlint --fix --config ../../oxlint.json .",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/client-sesv2": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@quieter/config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
