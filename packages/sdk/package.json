{
  "name": "quieter",
  "version": "0.0.1",
  "description": "TypeScript SDK for the Quieter send API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quieter-email/quieter"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./email-sdk": {
      "types": "./dist/email-sdk.d.ts",
      "default": "./dist/email-sdk.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && bun build ./src/index.ts ./src/email-sdk.ts --outdir ./dist --target browser --format esm --packages external && tsgo --project ./tsconfig.build.json",
    "fmt": "oxfmt --config ../../oxfmt.json .",
    "fmt:check": "oxfmt --check --config ../../oxfmt.json .",
    "lint": "bun --cwd ../.. oxlint --config oxlint.json packages/sdk",
    "lint:fix": "bun --cwd ../.. oxlint --fix --config oxlint.json packages/sdk",
    "prepublishOnly": "bun run build && bun run fmt:check && bun run lint && bun run typecheck",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@react-email/render": "^2.0.9",
    "@types/react": "^19.2.17",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@opencoredev/email-sdk": "^0.6.5",
    "@quieter/config": "workspace:*",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@opencoredev/email-sdk": "^0.6.5"
  },
  "peerDependenciesMeta": {
    "@opencoredev/email-sdk": {
      "optional": true
    }
  }
}
