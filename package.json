    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "scripts": {
    "build": "turbo run build",
    "db:generate": "turbo run db:generate --filter=@quietr/database",
    "db:migrate": "turbo run db:migrate --filter=@quietr/database",
    "db:push": "turbo run db:push --filter=@quietr/database",
    "dev": "turbo run dev",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "mail:deploy": "turbo run sst:deploy --filter=@quietr/aws",
    "mail:deploy:production": "turbo run sst:deploy:production --filter=@quietr/aws",
    "mail:dev": "turbo run sst:dev --filter=@quietr/aws",
    "mail:diff": "turbo run sst:diff --filter=@quietr/aws",
    "mail:remove": "turbo run sst:remove --filter=@quietr/aws",
    "mail:remove:production": "turbo run sst:remove:production --filter=@quietr/aws",
    "sst:deploy": "turbo run sst:deploy --filter=@quietr/aws",
    "sst:dev": "turbo run sst:dev --filter=@quietr/aws",
    "sst:diff": "turbo run sst:diff --filter=@quietr/aws",
    "sst:remove": "turbo run sst:remove --filter=@quietr/aws",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2"
  },
  "devDependencies": {
    "sst": "^4.7.3",
    "turbo": "^2.9.6",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "@better-auth/core": "1.5.0",
    "@better-auth/utils": "0.3.1",
    "@tanstack/query-core": "5.96.2",
    "better-call": "1.3.2"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.12"
}
