      "drizzle-orm": "beta",
      "motion": "^12.38.0",
      "next": "^16.2.3",
      "next-themes": "^0.4.6",
      "nuqs": "^2.8.9",
      "oxfmt": "^0.45.0",
      "oxlint": "^1.60.0",
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.2.2",
      "typescript": "^6.0.2",
      "vaul": "^1.1.2",
      "zod": "^4.3.6"
