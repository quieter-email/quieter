{
  "name": "quieter",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@aws-sdk/client-s3": "^3.1034.0",
      "@aws-sdk/client-ses": "^3.1034.0",
      "@aws-sdk/client-sesv2": "^3.1034.0",
      "@types/bun": "^1.3.12",
      "@types/node": "^25.6.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@base-ui/react": "^1.4.1",
      "@tailwindcss/vite": "^4.2.4",
      "@hugeicons/core-free-icons": "^4.1.1",
      "@hugeicons/react": "^1.1.6",
      "@tanstack/query-core": "^5.99.2",
      "@tanstack/react-form": "^1.29.1",
      "@tanstack/react-hotkeys": "^0.9.1",
      "@tanstack/query-persist-client-core": "^5.99.2",
      "@tanstack/react-query": "^5.99.2",
      "@tanstack/react-store": "^0.11.0",
      "@tanstack/react-virtual": "^3.13.24",
      "@tanstack/store": "^0.11.0",
      "@orpc/client": "^1.14.0",
      "@orpc/server": "^1.14.0",
      "@orpc/tanstack-query": "^1.14.0",
      "better-auth": "1.5.0",
      "@tailwindcss/postcss": "^4.2.4",
      "@better-auth/core": "1.5.0",
      "@better-auth/passkey": "1.5.0",
      "@tanstack/react-router": "^1.168.23",
      "@tanstack/react-start": "^1.167.42",
      "@tanstack/zod-adapter": "^1.166.9",
      "@typescript/native-preview": "^7.0.0-dev.20260422.1",
      "@vitejs/plugin-react": "^6.0.1",
      "drizzle-kit": "beta",
      "drizzle-orm": "beta",
      "motion": "^12.38.0",
      "next-themes": "^0.4.6",
      "nitro": "3.0.260415-beta",
      "oxfmt": "^0.46.0",
      "oxlint": "^1.61.0",
      "react": "^19.2.5",
      "react-dom": "^19.2.5",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.2.4",
      "typescript": "^6.0.3",
      "vaul": "^1.1.2",
      "vite": "^8.0.9",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "db:generate": "turbo run db:generate --filter=@quieter/database",
    "db:migrate": "turbo run db:migrate --filter=@quieter/database",
    "db:push": "turbo run db:push --filter=@quieter/database",
    "dev": "turbo run dev",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "generate:assets": "bun scripts/generate-web-assets.ts",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "prepare": "husky",
    "sst": "bun scripts/sst.ts",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "sst": "^4.10.1",
    "turbo": "^2.9.6",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "@better-auth/core": "1.5.0",
    "@better-auth/utils": "0.3.1",
    "@tanstack/query-core": "5.96.2",
    "better-call": "1.3.2"
  },
  "lint-staged": {
    "**/*": [
      "oxlint --fix --config oxlint.json",
      "oxfmt --config oxfmt.json",
      "tsgo --noEmit",
      "test"
    ]
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.13",
  "catalog": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}

