  "scripts": {
    "billing:sync-credit-usage-polar": "vp run @quieter/billing#credit-usage:sync",
    "billing:sync-polar": "vp run @quieter/billing#catalog:sync",
    "build": "vp run -r build",
    "check:boundaries": "vp run @quieter/aws#check:boundaries",
    "check:bundles": "vp run @quieter/aws#check:bundles",
    "check:copy": "bun scripts/check-no-middle-dot.ts",
    "db:check": "vp run @quieter/database#db:check",
    "db:deploy": "vp run @quieter/database#db:deploy",
    "db:generate": "vp run @quieter/database#db:generate",
    "db:migrate": "vp run @quieter/database#db:migrate",
    "db:push": "vp run @quieter/database#db:push",
    "db:test-migrations": "vp run @quieter/database#db:test-migrations",
    "dev": "bun --env-file=.env.local packages/database/scripts/assert-local-development.ts && vp run @quieter/web#dev",
    "dev:all": "bun --env-file=.env.local packages/database/scripts/assert-local-development.ts && vp run --parallel --filter=@quieter/web --filter=@quieter/aws dev",
    "dev:mail": "bun --env-file=.env.local packages/database/scripts/assert-local-development.ts && vp run @quieter/aws#dev",
    "dev:web": "bun --env-file=.env.local packages/database/scripts/assert-local-development.ts && vp run @quieter/web#dev",
    "env:doctor": "bun scripts/env-doctor.ts",
    "generate:assets": "bun scripts/generate-web-assets.ts",
    "prepare": "vp config --no-agent",
    "sst": "bun scripts/sst.ts"
  },
  "devDependencies": {
    "@quieter/env": "workspace:*",
    "eslint-plugin-better-tailwindcss": "4.5.0",
    "sst": "^4.17.0",
    "tw-animate-css": "^1.4.0",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "@aws-sdk/util-dynamodb": "3.996.3",
    "@better-auth/api-key": "1.5.0",
    "@better-auth/core": "1.5.0",
    "@better-auth/passkey": "1.5.0",
    "@better-auth/utils": "0.3.1",
    "better-auth": "1.5.0",
    "better-call": "1.3.2",
    "vite": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.14"
}
