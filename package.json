  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.10",
      "@types/node": "^25.4.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@base-ui/react": "^1.2.0",
      "@hugeicons/core-free-icons": "^4.0.0",
      "@hugeicons/react": "^1.1.6",
      "@tanstack/query-persist-client-core": "^5.92.1",
      "@tanstack/react-query": "^5.90.21",
      "@tanstack/react-virtual": "^3.13.21",
      "better-auth": "1.5.0",
      "@tailwindcss/postcss": "^4.2.1",
      "@trpc/client": "^11.12.0",
      "@trpc/server": "^11.12.0",
      "@better-auth/core": "1.5.0",
      "@better-auth/passkey": "1.5.0",
      "@typescript/native-preview": "^7.0.0-dev.20260310.1",
      "drizzle-kit": "beta",
      "drizzle-orm": "beta",
      "motion": "^12.35.2",
      "next": "^16.1.6",
      "next-themes": "^0.4.6",
      "nuqs": "^2.8.9",
      "oxfmt": "^0.37.0",
      "oxlint": "^1.52.0",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "tailwindcss": "^4.2.1",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "db:generate": "turbo run db:generate --filter=@quietr/database",
    "db:migrate": "turbo run db:migrate --filter=@quietr/database",
    "db:push": "turbo run db:push --filter=@quietr/database",
    "dev": "turbo run dev",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2"
  },
  "devDependencies": {
    "turbo": "^2.8.16",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "@better-auth/core": "1.5.0",
    "@better-auth/utils": "0.3.1",
    "better-call": "1.3.2"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.10"
}
