{
  "name": "quieter",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@aws-sdk/client-apigatewaymanagementapi": "3.1063.0",
      "@aws-sdk/client-dynamodb": "3.1063.0",
      "@aws-sdk/client-s3": "^3.1048.0",
      "@aws-sdk/client-ses": "^3.1048.0",
      "@aws-sdk/client-sesv2": "^3.1048.0",
      "@aws-sdk/client-sqs": "^3.1048.0",
      "@aws-sdk/lib-dynamodb": "3.1063.0",
      "@types/bun": "^1.3.14",
      "@types/node": "^25.8.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@base-ui/react": "^1.4.1",
      "@tailwindcss/vite": "^4.3.0",
      "@hugeicons/core-free-icons": "^4.1.4",
      "@hugeicons/react": "^1.1.6",
      "@tanstack/query-core": "^5.100.10",
      "@tanstack/react-form": "^1.32.0",
      "@tanstack/react-hotkeys": "^0.10.0",
      "@tanstack/query-persist-client-core": "^5.100.10",
      "@tanstack/react-query": "^5.100.10",
      "@tanstack/react-virtual": "^3.13.24",
      "@tanstack/ai": "0.18.0",
      "@tanstack/ai-openrouter": "0.9.1",
      "@tanstack/ai-react": "0.10.0",
      "@orpc/client": "^1.14.3",
      "@orpc/server": "^1.14.3",
      "@orpc/tanstack-query": "^1.14.3",
      "better-auth": "1.5.0",
      "@tailwindcss/postcss": "^4.3.0",
      "@better-auth/core": "1.5.0",
      "@better-auth/passkey": "1.5.0",
      "@tanstack/react-router": "^1.170.0",
      "@tanstack/react-start": "^1.168.0",
      "@tanstack/zod-adapter": "^1.167.0",
      "@t3-oss/env-core": "0.13.11",
      "@typescript/native-preview": "^7.0.0-dev.20260515.1",
      "@vitejs/plugin-react": "^6.0.2",
      "drizzle-kit": "beta",
      "drizzle-orm": "beta",
      "motion": "^12.38.0",
      "next-themes": "^0.4.6",
      "nitro": "3.0.260415-beta",
      "oxfmt": "^0.50.0",
      "oxlint": "^1.65.0",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.3.0",
      "typescript": "^6.0.3",
      "vaul": "^1.1.2",
      "vite": "^8.0.13",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "consent:migrate": "turbo run consent:migrate --filter=@quieter/web",
    "db:check": "turbo run db:check --filter=@quieter/database",
    "db:deploy": "turbo run db:deploy --filter=@quieter/database",
    "db:generate": "turbo run db:generate --filter=@quieter/database",
    "db:migrate": "turbo run db:migrate --filter=@quieter/database",
    "db:test-migrations": "turbo run db:test-migrations --filter=@quieter/database",
    "db:push": "turbo run db:push --filter=@quieter/database",
    "dev": "bun --env-file=.env.local packages/database/scripts/assert-local-development.ts && turbo run dev",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "generate:assets": "bun scripts/generate-web-assets.ts",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "prepare": "husky",
    "sst": "bun scripts/sst.ts",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0"
  },
  "devDependencies": {
    "@quieter/env": "workspace:*",
    "eslint-plugin-better-tailwindcss": "4.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "sst": "^4.14.1",
    "turbo": "^2.9.16",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "@aws-sdk/util-dynamodb": "3.996.3",
    "@better-auth/api-key": "1.5.0",
    "@better-auth/core": "1.5.0",
    "@better-auth/passkey": "1.5.0",
    "@better-auth/utils": "0.3.1",
    "@tanstack/query-core": "5.100.9",
    "better-auth": "1.5.0",
    "better-call": "1.3.2",
    "kysely": "0.28.11"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,jsonc}": "oxfmt --config oxfmt.json",
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": "oxlint --fix --config oxlint.json"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
