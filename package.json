      "@tanstack/react-query": "^5.99.0",
      "@tanstack/react-store": "^0.10.0",
      "@tanstack/react-virtual": "^3.13.23",
      "@tanstack/store": "^0.10.0",
      "@orpc/client": "^1.13.14",
      "@orpc/server": "^1.13.14",
      "@orpc/tanstack-query": "^1.13.14",
      "better-auth": "1.5.0",
