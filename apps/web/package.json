{
  "name": "@quietr/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --env-file=../../.env.local next build",
    "dev": "bun --env-file=../../.env.local next dev --port 3000",
    "fmt": "oxfmt --config ../../oxfmt.json .",
    "fmt:check": "oxfmt --check --config ../../oxfmt.json .",
    "lint": "oxlint --config ../../oxlint.json .",
    "lint:fix": "oxlint --fix --config ../../oxlint.json .",
    "start": "bun --env-file=../../.env.local next start --port 3000",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@better-auth/passkey": "catalog:",
    "@hugeicons/core-free-icons": "catalog:",
