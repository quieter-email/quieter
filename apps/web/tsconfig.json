{
  "extends": "@quieter/config/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["bun", "vite/client"],
    "paths": {
      "~/*": ["./src/*"]
