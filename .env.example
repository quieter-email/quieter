# App runtime
# Use http://localhost:3000 locally. In production, set this to the deployed app URL.
BETTER_AUTH_URL="http://localhost:3000"
# Optional local/private preview gate.
APP_SITE_PASSWORD="local-preview-password"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/quieter"
# DATABASE_MIGRATION_URL is intentionally absent. Local migrations fall back to DATABASE_URL.
# Production keeps its separate migration role credential only in the protected GitHub environment.

# Auth core
# Generate a unique value with at least 32 random characters per environment.
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_APP_NAME="quieter"

# Google authentication requests identity scopes only.
GOOGLE_AUTH_CLIENT_ID="your-google-auth-oauth-client-id"
GOOGLE_AUTH_CLIENT_SECRET="your-google-auth-oauth-client-secret"
# Gmail uses a separate OAuth client, requests https://mail.google.com/, and redirects to /api/gmail/callback.
GOOGLE_GMAIL_CLIENT_ID="your-google-gmail-oauth-client-id"
GOOGLE_GMAIL_CLIENT_SECRET="your-google-gmail-oauth-client-secret"
# Legacy key retained only while credentials encrypted before the current key are migrated.
GMAIL_TOKEN_ENCRYPTION_KEY="replace-with-a-random-encryption-secret"
# Generate a unique high-entropy value used for all new Gmail credential encryption.
GMAIL_TOKEN_ENCRYPTION_KEY_CURRENT="replace-with-a-different-random-encryption-secret"
# Set the same deployment-only token in Vercel and the GitHub production environment.
GMAIL_CREDENTIAL_ROTATION_TOKEN="replace-with-a-random-rotation-token"
GOOGLE_API_KEY="your-google-api-key"

# Gmail Pub/Sub (required together for production SST deploys; optional as a complete group locally).
# The topic must be in the same Google Cloud project as GOOGLE_GMAIL_CLIENT_ID.
GMAIL_PUBSUB_TOPIC="projects/your-project/topics/quieter-gmail"
GMAIL_PUBSUB_SUBSCRIPTION="projects/your-project/subscriptions/quieter-gmail-push"
GMAIL_PUBSUB_PUSH_SERVICE_ACCOUNT="quieter-gmail-push@your-project.iam.gserviceaccount.com"
GMAIL_PUBSUB_PUSH_AUDIENCE="https://quieter.email/gmail-pubsub"
# Generated by the SST GmailLiveSyncApi output and synced to Vercel in production.
GMAIL_LIVE_SYNC_URL="wss://your-api-id.execute-api.us-east-1.amazonaws.com/$default"
# Set the same high-entropy value in Vercel and the SST GmailLiveSyncTokenSecret.
GMAIL_LIVE_SYNC_TOKEN_SECRET="replace-with-a-random-live-sync-secret"
# Generated by the SST ChatGenerationEnqueue output and synced to Vercel in production.
CHAT_GENERATION_START_URL="https://your-chat-generation-function-url"
# Set the same value in Vercel and the SST ChatGenerationStartToken secret.
CHAT_GENERATION_START_TOKEN="replace-with-a-random-chat-generation-secret"

# Microsoft OAuth is not used right now! Keep unset unless Microsoft account linking is enabled.
# MICROSOFT_CLIENT_ID="your-microsoft-oauth-client-id"
# MICROSOFT_CLIENT_SECRET="your-microsoft-oauth-client-secret"
# MICROSOFT_CLIENT_SECRET_ID="your-microsoft-client-secret-id"

# logo.dev
VITE_LOGO_DEV_PUBLISHABLE_KEY="your-logo-dev-publishable-key"

# AI providers
OPENROUTER_API_KEY="sk-or-your-openrouter-api-key"

# PostHog analytics
# Used for pageviews and identified users only. Autocapture/session recording stay disabled in code.
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN="your-posthog-project-token"
VITE_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Sentry error monitoring
# VITE_SENTRY_DSN is for browser errors. SENTRY_DSN is for server errors.
# SENTRY_AUTH_TOKEN is only needed during builds for source map uploads.
# SENTRY_ORG and SENTRY_PROJECT should match apps/web/vite.config.ts if that config changes.
VITE_SENTRY_DSN="https://public@sentry.example/project"
SENTRY_DSN="https://public@sentry.example/project"
SENTRY_ENVIRONMENT="development"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Auth email / outbound mail
# QUIETER_MAIL_API_KEY should be an organization API key for the organization that owns the auth sender domain.
# QUIETER_MAIL_API_URL defaults to BETTER_AUTH_URL + /api/messages when unset.
QUIETER_MAIL_API_KEY="organization-api-key-for-auth-mail"
QUIETER_AUTH_MAIL_SENDER="auth@quieter.email"
QUIETER_MAIL_API_URL="http://localhost:3000/api/messages"
# These SST outputs are synced to Vercel in production and normally stay unset locally.
# MAIL_BUCKET="quieter-mail-bucket"
# MAIL_RECEIPT_TOPIC_ARN="arn:aws:sns:us-east-1:123456789012:quieter-mail"
# MAIL_RECEIPT_ROLE_ARN="arn:aws:iam::123456789012:role/quieter-mail-receipt"
# MAIL_RECEIPT_RULE_SET_NAME="quieter-mail"

# Billing / checkout
# Managed and Pro subscription products are synced from code into Polar.
# Use /api/billing/polar-webhook as the Polar webhook endpoint and enable order/customer/subscription/refund events from the PayKit Polar docs.
POLAR_ACCESS_TOKEN="polar_oat_or_pat"
POLAR_ORGANIZATION_ID="polar-organization-id"
POLAR_WEBHOOK_SECRET="polar_whsec_or_secret"
POLAR_SANDBOX="true"

# AWS / SST local commands
# Required for the mail S3 uploader and local SST mail stack.
AWS_REGION="us-east-1"
AWS_DEFAULT_REGION="us-east-1"
AWS_EC2_METADATA_DISABLED="true"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_SESSION_TOKEN="your-aws-session-token"

# Mail ingress/outbound bearer tokens are SST linked secrets, not env vars.
# Set them per stage with:
# bun run sst secret set MailIngestToken <random-token>
# bun run sst secret set MailSendToken <random-token>
