{
  "$schema": "https://v2-9-17.turborepo.dev/schema.json",
  "ui": "tui",
  "envMode": "strict",
  "globalDependencies": [".env*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "BETTER_AUTH_APP_NAME",
        "BETTER_AUTH_SECRET",
        "GOOGLE_AUTH_CLIENT_ID",
        "GOOGLE_AUTH_CLIENT_SECRET",
        "GOOGLE_GMAIL_CLIENT_ID",
        "GOOGLE_GMAIL_CLIENT_SECRET",
        "GMAIL_TOKEN_ENCRYPTION_KEY",
        "GMAIL_TOKEN_ENCRYPTION_KEY_CURRENT",
        "DATABASE_MIGRATION_URL",
        "DATABASE_URL",
        "VITE_LOGO_DEV_PUBLISHABLE_KEY",
        "OPENROUTER_API_KEY",
        "POLAR_ACCESS_TOKEN",
        "POLAR_ORGANIZATION_ID",
        "POLAR_SANDBOX",
        "POLAR_WEBHOOK_SECRET",
        "QUIETER_UNLIMITED_BILLING_EMAILS",
        "BETTER_AUTH_URL",
        "VITE_PUBLIC_C15T_URL",
        "VITE_PUBLIC_POSTHOG_PROJECT_TOKEN",
        "VITE_PUBLIC_POSTHOG_HOST",
        "VITE_SENTRY_DSN",
        "SENTRY_DSN",
        "SENTRY_ENVIRONMENT",
        "SENTRY_AUTH_TOKEN",
        "SENTRY_ORG",
        "SENTRY_PROJECT",
        "QUIETER_AUTH_MAIL_SENDER",
        "QUIETER_MAIL_API_KEY",
        "QUIETER_MAIL_API_URL",
        "MAIL_BUCKET",
        "MAIL_RECEIPT_TOPIC_ARN",
        "MAIL_RECEIPT_ROLE_ARN",
        "MAIL_RECEIPT_RULE_SET_NAME",
        "CHAT_GENERATION_START_URL",
        "CHAT_GENERATION_START_TOKEN",
        "GMAIL_CREDENTIAL_ROTATION_TOKEN",
        "GMAIL_LIVE_SYNC_URL",
        "GMAIL_LIVE_SYNC_TOKEN_SECRET"
      ],
      "passThroughEnv": [
        "GOOGLE_API_KEY",
        "APP_SITE_PASSWORD",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_EC2_METADATA_DISABLED",
        "VERCEL_ENV",
        "VERCEL_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", ".output/**", "!.output/cache/**", ".vercel/output/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "cache": false
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "outputs": [],
      "cache": false
    },
    "fmt": {
      "dependsOn": ["^fmt"],
      "outputs": [],
      "cache": false
    },
    "fmt:check": {
      "dependsOn": ["^fmt:check"],
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": [],
      "cache": false
    },
    "db:generate": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["drizzle/**"],
      "interactive": true
    },
    "db:check": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "db:deploy": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_MIGRATION_URL"],
      "cache": false,
      "outputs": []
    },
    "db:migrate": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_MIGRATION_URL", "DATABASE_URL"],
      "cache": false,
      "outputs": [],
      "interactive": false
    },
    "db:test-migrations": {
      "env": ["DATABASE_MIGRATION_URL"],
      "cache": false,
      "outputs": []
    },
    "db:push": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL"],
      "cache": false,
      "outputs": [],
      "interactive": true
    },
    "consent:migrate": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_MIGRATION_URL", "DATABASE_URL"],
      "cache": false,
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build"],
      "env": [
        "BETTER_AUTH_APP_NAME",
        "BETTER_AUTH_SECRET",
        "GOOGLE_AUTH_CLIENT_ID",
        "GOOGLE_AUTH_CLIENT_SECRET",
        "GOOGLE_GMAIL_CLIENT_ID",
        "GOOGLE_GMAIL_CLIENT_SECRET",
        "GMAIL_TOKEN_ENCRYPTION_KEY",
        "GMAIL_TOKEN_ENCRYPTION_KEY_CURRENT",
        "DATABASE_MIGRATION_URL",
        "DATABASE_URL",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_ROLE_ARN",
        "AWS_WEB_IDENTITY_TOKEN_FILE",
        "AWS_SHARED_CREDENTIALS_FILE",
        "AWS_CONFIG_FILE",
        "BUN_INSTALL_CACHE_DIR",
        "SST_BUN_PATH",
        "VITE_LOGO_DEV_PUBLISHABLE_KEY",
        "OPENROUTER_API_KEY",
        "POLAR_ACCESS_TOKEN",
        "POLAR_ORGANIZATION_ID",
        "POLAR_SANDBOX",
        "POLAR_WEBHOOK_SECRET",
        "QUIETER_UNLIMITED_BILLING_EMAILS",
        "BETTER_AUTH_URL",
        "VITE_PUBLIC_C15T_URL",
        "VITE_PUBLIC_POSTHOG_PROJECT_TOKEN",
        "VITE_PUBLIC_POSTHOG_HOST",
        "VITE_SENTRY_DSN",
        "SENTRY_DSN",
        "SENTRY_ENVIRONMENT",
        "QUIETER_AUTH_MAIL_SENDER",
        "QUIETER_MAIL_API_KEY",
        "QUIETER_MAIL_API_URL",
        "MAIL_BUCKET",
        "MAIL_RECEIPT_TOPIC_ARN",
        "MAIL_RECEIPT_ROLE_ARN",
        "MAIL_RECEIPT_RULE_SET_NAME",
        "CHAT_GENERATION_START_URL",
        "CHAT_GENERATION_START_TOKEN",
        "GMAIL_CREDENTIAL_ROTATION_TOKEN",
        "GMAIL_LIVE_SYNC_URL",
        "GMAIL_LIVE_SYNC_TOKEN_SECRET",
        "VERCEL_ENV",
        "VERCEL_URL"
      ],
      "passThroughEnv": ["BUN_INSTALL_CACHE_DIR", "SST_BUN_PATH"],
      "cache": false,
      "persistent": true
    }
  }
}
