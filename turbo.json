{
  "$schema": "https://v2-9-4.turborepo.dev/schema.json",
  "ui": "tui",
  "envMode": "strict",
  "globalDependencies": [".env*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "BETTER_AUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DATABASE_URL",
        "VITE_LOGO_DEV_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".output/**", "!.output/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "cache": false
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "outputs": [],
      "cache": false
    },
    "fmt": {
      "dependsOn": ["^fmt"],
      "outputs": [],
      "cache": false
    },
    "fmt:check": {
      "dependsOn": ["^fmt:check"],
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "db:generate": {
      "env": ["DATABASE_URL"],
      "cache": false,
      "outputs": ["drizzle/**"]
    },
    "db:migrate": {
      "env": ["DATABASE_URL"],
      "cache": false,
      "outputs": []
    },
    "db:push": {
      "env": ["DATABASE_URL"],
      "cache": false,
      "outputs": []
    },
    "sst:deploy": {
      "env": [
        "DATABASE_URL",
        "MAIL_S3_PREFIX",
        "EMAIL_S3_PREFIX",
        "MANAGED_MAIL_S3_PREFIX",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_ROLE_ARN",
        "AWS_WEB_IDENTITY_TOKEN_FILE",
        "AWS_SHARED_CREDENTIALS_FILE",
        "AWS_CONFIG_FILE"
      ],
      "cache": false,
      "outputs": []
    },
    "sst:deploy:production": {
      "env": [
        "DATABASE_URL",
        "MAIL_S3_PREFIX",
        "EMAIL_S3_PREFIX",
        "MANAGED_MAIL_S3_PREFIX",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_ROLE_ARN",
        "AWS_WEB_IDENTITY_TOKEN_FILE",
        "AWS_SHARED_CREDENTIALS_FILE",
        "AWS_CONFIG_FILE"
      ],
      "cache": false,
      "outputs": []
    },
    "sst:diff": {
      "env": [
        "DATABASE_URL",
        "MAIL_S3_PREFIX",
        "EMAIL_S3_PREFIX",
        "MANAGED_MAIL_S3_PREFIX",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_ROLE_ARN",
        "AWS_WEB_IDENTITY_TOKEN_FILE",
        "AWS_SHARED_CREDENTIALS_FILE",
        "AWS_CONFIG_FILE"
      ],
      "cache": false,
      "outputs": []
    },
    "sst:remove": {
      "env": [
        "DATABASE_URL",
        "MAIL_S3_PREFIX",
        "EMAIL_S3_PREFIX",
        "MANAGED_MAIL_S3_PREFIX",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_ROLE_ARN",
        "AWS_WEB_IDENTITY_TOKEN_FILE",
        "AWS_SHARED_CREDENTIALS_FILE",
        "AWS_CONFIG_FILE"
      ],
      "cache": false,
      "outputs": []
    },
    "sst:remove:production": {
      "env": [
        "DATABASE_URL",
        "MAIL_S3_PREFIX",
        "EMAIL_S3_PREFIX",
        "MANAGED_MAIL_S3_PREFIX",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_ROLE_ARN",
        "AWS_WEB_IDENTITY_TOKEN_FILE",
        "AWS_SHARED_CREDENTIALS_FILE",
        "AWS_CONFIG_FILE"
      ],
      "cache": false,
      "outputs": []
    },
    "dev": {
      "env": [
        "BETTER_AUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DATABASE_URL",
        "VITE_LOGO_DEV_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY"
      ],
      "cache": false,
      "persistent": true
    },
    "sst:dev": {
      "env": [
        "DATABASE_URL",
        "MAIL_S3_PREFIX",
        "EMAIL_S3_PREFIX",
        "MANAGED_MAIL_S3_PREFIX",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_ROLE_ARN",
        "AWS_WEB_IDENTITY_TOKEN_FILE",
        "AWS_SHARED_CREDENTIALS_FILE",
        "AWS_CONFIG_FILE"
      ],
      "cache": false,
      "persistent": true
    }
  }
}
