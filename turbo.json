{
  "$schema": "https://v2-9-12.turborepo.dev/schema.json",
  "ui": "tui",
  "envMode": "strict",
  "globalDependencies": [".env*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "BETTER_AUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DATABASE_URL",
        "VITE_LOGO_DEV_PUBLISHABLE_KEY",
        "BETTER_AUTH_URL"
      ],
      "passThroughEnv": [
        "GOOGLE_API_KEY",
        "APP_SITE_PASSWORD",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_EC2_METADATA_DISABLED"
      ],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["dist/**", ".output/**", "!.output/cache/**", ".vercel/output/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "cache": false
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "outputs": [],
      "cache": false
    },
    "fmt": {
      "dependsOn": ["^fmt"],
      "outputs": [],
      "cache": false
    },
    "fmt:check": {
      "dependsOn": ["^fmt:check"],
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": [],
      "cache": false
    },
    "db:generate": {
      "env": ["DATABASE_URL"],
      "cache": false,
      "outputs": ["drizzle/**"],
      "interactive": true
    },
    "db:migrate": {
      "env": ["DATABASE_URL"],
      "cache": false,
      "outputs": [],
      "interactive": true
    },
    "db:push": {
      "env": ["DATABASE_URL"],
      "cache": false,
      "outputs": [],
      "interactive": true
    },
    "dev": {
      "env": [
        "BETTER_AUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DATABASE_URL",
        "AWS_REGION",
        "AWS_DEFAULT_REGION",
        "AWS_PROFILE",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_SESSION_TOKEN",
        "AWS_ROLE_ARN",
        "AWS_WEB_IDENTITY_TOKEN_FILE",
        "AWS_SHARED_CREDENTIALS_FILE",
        "AWS_CONFIG_FILE",
        "BUN_INSTALL_CACHE_DIR",
        "SST_BUN_PATH",
        "VITE_LOGO_DEV_PUBLISHABLE_KEY",
        "BETTER_AUTH_URL"
      ],
      "passThroughEnv": ["BUN_INSTALL_CACHE_DIR", "SST_BUN_PATH"],
      "cache": false,
      "persistent": true
    }
  }
}
